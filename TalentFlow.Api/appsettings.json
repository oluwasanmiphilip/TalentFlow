{
  "ConnectionStrings": {
    "Development": "Host=localhost;Port=5432;Database=talentflow_dev;Username=dev_user;Password=dev_password",
    "Production": "${ConnectionStrings__Production}"
  },

  "Termii": {
    "Production": {
      "ApiKey": "${Termii__Production__ApiKey}",
      "SenderId": "${Termii__Production__SenderId}"
    }
  },

  "FileStorage": {
    "BaseUrl": "https://api.yourdomain.com",
    "UploadsPath": "uploads"
  },

  "AllowedOrigins": [
    "http://localhost:5173",
    "https://talent-flow-kappa-six.vercel.app"
  ],

  "SmtpSettings": {
    "Server": "${SMTP_SERVER}",
    "Port": "${SMTP_PORT}",
    "SenderName": "${SMTP_SENDER_NAME}",
    "SenderEmail": "${SMTP_SENDER_EMAIL}",
    "Username": "${SMTP_USERNAME}",
    "Password": "${SMTP_PASSWORD}"
  },

  "Brevo": {
    "ApiKey": "${Brevo__ApiKey}",
    "SenderEmail": "${Brevo__SenderEmail}"
  },

  "SendGrid": {
    "ApiKey": "${SendGrid__ApiKey}"
  },

  "RabbitMQ": {
    "Development": {
      "Host": "localhost",
      "Port": "5672",
      "UserName": "guest",
      "Password": "guest"
    },
    "Production": {
      "Host": "${RabbitMQ__Production__Host}",
      "Port": "${RabbitMQ__Production__Port}",
      "UserName": "${RabbitMQ__Production__UserName}",
      "Password": "${RabbitMQ__Production__Password}"
    }
  },

  "Jwt": {
    "Development": { "Secret": "superlongjwtsecretkeytokenhiddenfor_dev" },
    "Production": { "Secret": "${Jwt__Production__Secret}" }
  }
}
